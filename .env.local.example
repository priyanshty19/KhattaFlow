# ── Database (Supabase) ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Session" mode URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── Clerk Auth ───────────────────────────────────────────────────────────────
# Get these from: clerk.com → Your App → API Keys
# Dev keys start with pk_test_ / sk_test_  (local development only)
# Production keys start with pk_live_ / sk_live_  (set on hosting platform)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
CLERK_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Clerk webhook signing secret — required for /api/webhooks/clerk to work
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Starts with whsec_
CLERK_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Clerk redirect URLs (page paths — required)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# Do NOT set NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL or NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL
# — they are deprecated. Redirects are controlled by ClerkProvider props in app/layout.tsx.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── AI Insights (Gemini) ─────────────────────────────────────────────────────
# Get this from: aistudio.google.com → Get API key
# Powers the AI-generated financial insights on the dashboard
GEMINI_API_KEY="AIza..."

# ── FinGrid Integration ───────────────────────────────────────────────────
# Secret key that FinGrid sends as the x-api-key header to /api/customer-lookup
CUSTOMER_LOOKUP_API_KEY="your-secret-api-key-here"

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Get these from: Google Cloud Console → APIs & Services → Credentials → OAuth client
# Both local and production MUST use the SAME OAuth client. On that client, register
# BOTH authorized redirect URIs:
#   http://localhost:3000/api/connect/gmail/callback   (local dev)
#   https://myfingrid.com/api/connect/gmail/callback    (production)
# Do NOT set GOOGLE_REDIRECT_URI — the callback URL is auto-derived from the request
# (see lib/utils/base-url.ts), so it is always correct per environment.
GOOGLE_CLIENT_ID="XXXXXXXXXXXX-xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-XXXXXXXXXXXXXXXXXXXX"

# ── Cron / shared secrets ──────────────────────────────────────────────────────
OTP_SECRET="a-32+-char-random-secret"   # also keys AES token encryption — keep stable
CRON_SECRET="random-secret-for-cron-endpoints"

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ ENV HYGIENE — local vs production                                              ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║ • Never `vercel env add` by piping from .env.local. Local-only values          ║
# ║   (localhost URLs, dev secrets, *-local-dev-key, pk_test_/sk_test_) must        ║
# ║   never reach Vercel.                                                           ║
# ║ • Set production values explicitly in the Vercel dashboard, scoped to the       ║
# ║   Production environment only.                                                  ║
# ║ • There is intentionally NO GOOGLE_REDIRECT_URI / per-env OAuth URL var.        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
