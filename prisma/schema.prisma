// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id // Clerk userId
  email           String   @unique
  name            String?
  monthlySalary   Int?     // paise
  currency        String   @default("INR")
  savingsGoalPct  Float    @default(0.20)
  companyName     String?
  investmentStyle String?  // 'conservative' | 'balanced' | 'aggressive'
  phone           String?  @unique
  creditScore     Int?     // CIBIL score 300–900, captured at onboarding
  employmentType  String?  // 'salaried' | 'self_employed' | 'business_owner' | 'student'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories           Category[]
  transactions         Transaction[]
  budgets              Budget[]
  recurringRules       RecurringRule[]
  imports              Import[]
  monthlySummaries     MonthlySummary[]
  otpVerifications     OtpVerification[]
  oauthConnections     OAuthConnection[]
  creditCardPreference        CreditCardPreference?
  cardRecommendations         CardRecommendation[]
  userCreditCards             UserCreditCard[]
  cardRecommendationFeedbacks CardRecommendationFeedback[]
  cardApplyIntents            CardApplyIntent[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  slug      String
  type      CategoryType
  color     String
  icon      String?
  isFixed   Boolean  @default(false)
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  group     String?
  createdAt DateTime @default(now())
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  recurringRules RecurringRule[]

  @@unique([userId, slug])
  @@map("categories")
}

enum CategoryType {
  income
  expense
  investment
  savings
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  categoryId    String
  amount        Int      // paise, always positive
  type          CategoryType
  paymentMethod PaymentMethod?
  description   String?
  notes         String?
  date          DateTime @db.Date
  month         String   // '2026-05' — computed on insert
  year          Int      // 2026 — computed on insert
  isRecurring   Boolean  @default(false)
  recurringId   String?
  importId      String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  import   Import?   @relation(fields: [importId], references: [id])

  @@index([userId, month])
  @@index([userId, year])
  @@index([categoryId])
  @@index([date(sort: Desc)])
  @@map("transactions")
}

enum PaymentMethod {
  cash
  credit_card
  upi
  bank_transfer
  auto_debit
}

model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  month      String   // '2026-05'
  amount     Int      // paise
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month])
  @@index([userId, month])
  @@map("budgets")
}

model RecurringRule {
  id          String    @id @default(uuid())
  userId      String
  categoryId  String
  amount      Int       // paise
  description String?
  frequency   String    // 'monthly' | 'weekly'
  dayOfMonth  Int?      // 1-31
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("recurring_rules")
}

model Import {
  id           String   @id @default(uuid())
  userId       String
  filename     String
  rowCount     Int
  status       ImportStatus
  errorLog     Json     @default("[]")
  createdAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("imports")
}

enum ImportStatus {
  pending
  success
  failed
}

model MonthlySummary {
  id                 String   @id @default(uuid())
  userId             String
  month              String   // '2026-05'
  totalIncome        Int      @default(0)
  totalExpenses      Int      @default(0)
  totalSavings       Int      @default(0)
  totalInvestments   Int      @default(0)
  netBalance         Int      @default(0)
  transactionCount   Int      @default(0)
  computedAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@map("monthly_summaries")
}

model OtpVerification {
  id         String   @id @default(uuid())
  identifier String
  codeHash   String
  sessionId  String   @unique @default(uuid())
  expiresAt  DateTime
  used       Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([identifier])
  @@index([sessionId])
  @@map("otp_verifications")
}

model OAuthConnection {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  providerEmail   String
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime?
  scopes          String
  gmailHistoryId  String?   // Gmail History API cursor — null means no prior sync
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, providerEmail])
  @@map("oauth_connections")
}

// Tracks every Gmail message we've already imported — prevents duplicate transactions
model EmailImportLog {
  id             String   @id @default(uuid())
  userId         String
  gmailMessageId String
  importedAt     DateTime @default(now())

  @@unique([userId, gmailMessageId])
  @@index([userId])
  @@map("email_import_logs")
}

// ─── CredWise / Credit Card Recommender ──────────────────────────────────────

model CreditCard {
  id                       String   @id @default(uuid())
  cardName                 String
  bank                     String
  cardType                 String
  creditScoreRequirement   Int      @default(0)
  monthlyIncomeRequirement Int      @default(0)
  joiningFee               Int      @default(0)
  annualFee                Int      @default(0)
  feeWaiverThreshold       Int      @default(0)
  rewardType               String   // 'cashback' | 'points' | 'miles' | 'hybrid'
  pointValue               Float    @default(0)
  baseRewardRate           Float    @default(0)
  categoryRewardRates      Json     @default("{}")
  categoryCaps             Json     @default("{}")
  signUpBonus              Int      @default(0)
  signUpSpendRequired      Int      @default(0)
  signUpWindowDays         Int      @default(0)
  milestoneDependency      Boolean  @default(false)
  minAnnualSpend           Int      @default(0)
  milestoneBonus           Int      @default(0)
  milestoneBenefitDesc     String?
  loungeAccess             String   @default("none")
  loungeVisitsPerYear      Int      @default(0)
  forexMarkup              Float    @default(0)
  fuelSurchargeWaiver      Boolean  @default(false)
  bestForTags              String[]
  features                 String?
  spendingCategories       String[]
  isActive                 Boolean  @default(true)
  // v3 fields
  platformCoverage         Float    @default(1.0)   // 0.0–1.0: fraction of category spend at special rate (merchant-specific cards)
  platformNote             String?                   // e.g. "Only on Swiggy orders"
  loungeValuePerVisit      Int      @default(700)   // ₹ per visit — domestic avg ₹700, intl ₹1200
  milestones               Json     @default("[]")  // MilestoneTier[] — replaces single milestone fields
  networkType              String   @default("Visa") // 'Visa' | 'Mastercard' | 'RuPay' | 'Amex' | 'Diners'
  employmentRequirement    String   @default("any") // 'any' | 'salaried' | 'self_employed'
  applyUrl                 String?                   // Direct application link
  imageUrl                 String?                   // Card art image URL
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([bank])
  @@index([isActive])
  @@map("credit_cards")
}

// Lazy — only created when user first uses the Credit Card Recommender
model CreditCardPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  joiningFeePreference String   @default("no_concern") // 'no_fee' | 'low_fee' | 'no_concern'
  preferredBanks       String[]
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_card_preferences")
}

// Per-user recommendation cache — one entry per month, refreshed on demand
model CardRecommendation {
  id              String   @id @default(uuid())
  userId          String
  month           String   // '2026-05'
  recommendations Json     // ScoredCard[] top 7
  userSnapshot    Json     // UserProfile used for this run
  spendSource     String   @default("manual") // 'auto' | 'manual'
  computedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@map("card_recommendations")
}

// Feedback on card recommendations — used for ML training
model CardRecommendationFeedback {
  id               String   @id @default(uuid())
  userId           String
  liked            Boolean  // true = Yes, false = No
  preferredCard    String?  // free-text: "which card would you prefer?" (only when liked=false)
  recommendedCards String[] // card IDs of what was shown
  month            String   // '2026-05' — which recommendation set this was for
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("card_recommendation_feedback")
}

// Apply intent — logged every time a user clicks "Apply Now" on a card
model CardApplyIntent {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  cardName  String
  bank      String
  month     String   // '2026-05'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cardId])
  @@map("card_apply_intents")
}

// User's own cards — manually tracked (no utilisation in this version)
model UserCreditCard {
  id           String   @id @default(uuid())
  userId       String
  cardName     String
  bank         String
  last4        String?
  creditLimit  Int?     // paise
  statementDay Int?     // 1–31, day of month statement is generated
  dueDay       Int?     // days after statement date when payment is due
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_credit_cards")
}
